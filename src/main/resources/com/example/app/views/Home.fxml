<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.app.controllers.HomeController"
      spacing="20"
      style="-fx-background-color: #121212; -fx-padding: 20;">
    
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    
    <!-- Welcome Section -->
    <VBox spacing="10">
        <Label text="Welcome to NestTunes" 
               style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
        <Label text="Your personal music streaming platform" 
               style="-fx-text-fill: #b3b3b3; -fx-font-size: 16px;"/>
    </VBox>
    
    <!-- Recently Played Section -->
    <VBox spacing="10">
        <Label text="Recently Played" 
               style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <HBox spacing="20" style="-fx-padding: 10;">
                <!-- Placeholder for recently played tracks -->
                <Label text="No recent tracks" 
                       style="-fx-text-fill: #b3b3b3; -fx-font-size: 14px;"/>
            </HBox>
        </ScrollPane>
    </VBox>
    
    <!-- Your Playlists Section -->
    <VBox spacing="10">
        <Label text="Your Playlists" 
               style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <VBox spacing="10" style="-fx-padding: 10;">
                <!-- Placeholder for playlists -->
                <Label text="No playlists yet" 
                       style="-fx-text-fill: #b3b3b3; -fx-font-size: 14px;"/>
            </VBox>
        </ScrollPane>
    </VBox>
</VBox>
