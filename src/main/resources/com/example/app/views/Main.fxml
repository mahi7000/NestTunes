<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.fxml.FXMLLoader?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.app.controllers.MainController"
            stylesheets="@../styles/navbar.css">
    
    <!-- Left side navigation -->
    <left>
        <fx:include source="navbar.fxml"/>
    </left>
    
    <!-- Main content area -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #121212;"/>
    </center>
    
    <!-- Bottom player controls -->
    <bottom>
        <VBox style="-fx-background-color: #181818; -fx-padding: 10;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <!-- Now playing info -->
                <Label fx:id="nowPlayingLabel" style="-fx-text-fill: white;"/>
                
                <Region HBox.hgrow="ALWAYS"/>
                
                <!-- Player controls -->
                <Button fx:id="previousButton" styleClass="player-button"/>
                <Button fx:id="playPauseButton" styleClass="player-button"/>
                <Button fx:id="nextButton" styleClass="player-button"/>
                
                <!-- Volume control -->
                <Slider fx:id="volumeSlider" prefWidth="100"/>
            </HBox>
            
            <!-- Progress bar -->
            <Slider fx:id="progressSlider" styleClass="progress-slider"/>
        </VBox>
    </bottom>
</BorderPane>
